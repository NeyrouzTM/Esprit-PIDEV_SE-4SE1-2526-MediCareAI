# Staging Environment Configuration

# Deployment Details
DEPLOY_HOST=staging-server.medicare-ai.com
DEPLOY_USER=deploy
DEPLOY_PATH=/opt/medicare-ai
DEPLOY_KEY=/home/deploy/.ssh/id_rsa

# Database Configuration
DB_URL=jdbc:mysql://staging-db:3306/medicare_ai?useSSL=true&serverTimezone=UTC
DB_USERNAME=medicare_user
DB_PASSWORD=${STAGING_DB_PASSWORD}

# Email Configuration
MAIL_HOST=smtp.gmail.com
MAIL_PORT=587
MAIL_USERNAME=${STAGING_MAIL_USERNAME}
MAIL_PASSWORD=${STAGING_MAIL_PASSWORD}

# JWT Configuration
JWT_SECRET=${STAGING_JWT_SECRET}

# API Configuration
API_URL=https://staging-api.medicare-ai.com
CORS_ALLOWED_ORIGINS=https://staging.medicare-ai.com,https://www.staging.medicare-ai.com

# Redis Configuration
REDIS_HOST=staging-redis
REDIS_PORT=6379

# Monitoring
LOG_LEVEL=INFO

