# Production Environment Configuration

# Deployment Details
DEPLOY_HOST=prod-server.medicare-ai.com
DEPLOY_USER=deploy
DEPLOY_PATH=/opt/medicare-ai
DEPLOY_KEY=/home/deploy/.ssh/id_rsa

# Database Configuration
DB_URL=jdbc:mysql://prod-db-cluster:3306/medicare_ai?useSSL=true&serverTimezone=UTC&rewriteBatchedStatements=true
DB_USERNAME=medicare_prod_user
DB_PASSWORD=${PROD_DB_PASSWORD}

# Email Configuration
MAIL_HOST=${PROD_MAIL_HOST}
MAIL_PORT=${PROD_MAIL_PORT}
MAIL_USERNAME=${PROD_MAIL_USERNAME}
MAIL_PASSWORD=${PROD_MAIL_PASSWORD}

# JWT Configuration
JWT_SECRET=${PROD_JWT_SECRET}

# API Configuration
API_URL=https://api.medicare-ai.com
CORS_ALLOWED_ORIGINS=https://medicare-ai.com,https://www.medicare-ai.com

# Redis Configuration (Cluster mode)
REDIS_HOST=prod-redis-cluster
REDIS_PORT=6379
REDIS_PASSWORD=${PROD_REDIS_PASSWORD}

# Monitoring & Security
LOG_LEVEL=WARN
SENTRY_DSN=${PROD_SENTRY_DSN}
NEWRELIC_LICENSE_KEY=${PROD_NEWRELIC_KEY}

# Backup Configuration
BACKUP_ENABLED=true
BACKUP_SCHEDULE=0 2 * * *

