# Environment Configuration Template
# Copy to .env and update with your values

# ===== Database Configuration =====
DB_URL=jdbc:mysql://localhost:3306/medicare_ai?useSSL=false&serverTimezone=UTC
DB_USERNAME=root
DB_PASSWORD=root
DB_HOST=localhost
DB_PORT=3306
DB_NAME=medicare_ai

# ===== Email Configuration =====
MAIL_HOST=smtp.gmail.com
MAIL_PORT=587
MAIL_USERNAME=your-email@gmail.com
MAIL_PASSWORD=your-app-password

# ===== JWT Configuration =====
JWT_SECRET=your-very-long-secret-key-min-32-chars-for-hs256-algorithm-change-in-production

# ===== API Configuration =====
API_URL=http://localhost:8080
API_PORT=8080
CONTEXT_PATH=/api

# ===== Server Configuration =====
SERVER_ENV=development
SPRING_PROFILES_ACTIVE=dev

# ===== AWS/Cloud Configuration (if needed) =====
# AWS_ACCESS_KEY_ID=
# AWS_SECRET_ACCESS_KEY=
# AWS_REGION=us-east-1
# AWS_S3_BUCKET=medicare-ai-bucket

# ===== Logging Configuration =====
LOG_LEVEL=INFO
LOG_FILE_PATH=/var/log/medicare-ai/app.log

# ===== Redis Configuration (if using caching) =====
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=

# ===== Security Configuration =====
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:4200
CORS_ALLOWED_METHODS=GET,POST,PUT,DELETE,OPTIONS
CORS_MAX_AGE=3600

# ===== Docker Configuration =====
DOCKER_REGISTRY=ghcr.io
DOCKER_IMAGE_NAME=medicare-ai-api
DOCKER_IMAGE_TAG=latest

# ===== Monitoring & Analytics =====
SENTRY_DSN=
NEWRELIC_LICENSE_KEY=

# ===== CI/CD Configuration =====
SONAR_HOST_URL=https://sonarqube.example.com
SONAR_TOKEN=
SLACK_WEBHOOK=https://hooks.slack.com/services/YOUR/WEBHOOK/URL

